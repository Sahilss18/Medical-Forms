# Database
DATABASE_URL=postgresql://medical_app:password@localhost:5432/medical_forms

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Application
PORT=3000
NODE_ENV=development

# Razorpay Configuration (Optional - for production)
# Get your keys from https://razorpay.com/ dashboard
# RAZORPAY_KEY_ID=your_razorpay_key_id
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# SMTP Configuration (required for real OTP/payment emails)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@example.com
# SMTP_PASS=your_app_password
# SMTP_FROM=your_email@example.com
